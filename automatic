def wait_for_csv(folder_path, prompt_msg):
    print(f"\n[BEKLENİYOR] {prompt_msg}")
    print(f"Hedef Klasör: {folder_path}")
    while True:
        csv_files = [f for f in os.listdir(folder_path) if f.endswith('.csv')]
        if csv_files:
            time.sleep(2) 
            print(f"[+] CSV dosyası algılandı: {csv_files[0]}")
            return os.path.join(folder_path, csv_files[0])
        time.sleep(3)

def copy_latest_log(logs_dir, dest_dir):
    print(f"\n[*] Log dosyası yedekleniyor...")
    try:
        csv_files = []
        for f in os.listdir(logs_dir):
            if f.lower().endswith('.csv') and 'threats' in f.lower():
                if not re.match(r'^\d{8}_', f):
                    csv_files.append(os.path.join(logs_dir, f))
        if not csv_files:
            print("[-] Uygun log dosyası bulunamadı.")
            return None
        latest_file = max(csv_files, key=os.path.getctime)
        hedef = os.path.join(dest_dir, os.path.basename(latest_file))
        shutil.copy2(latest_file, hedef)
        print(f"[+] Log dosyası kopyalandı: {os.path.basename(latest_file)}")
        return hedef
    except Exception as e:
        print(f"[!] Log kopyalama hatası: {e}")
        return None

def separator(csv_path, source_dir, dest_dir):
    df = pd.read_csv(csv_path, sep=None, engine='python')
    hash_col = 'sha256' if 'sha256' in df.columns else df.columns[0]
    bilinen_hashler = set(df[hash_col].astype(str).str.strip().str.lower())
    tasinan = toplam = 0
    print(f"[*] Ayıklama işlemi başlatıldı. CSV'den {len(bilinen_hashler)} kayıt okundu.")
    for root, dirs, files in os.walk(source_dir):
        if os.path.abspath(root) == os.path.abspath(dest_dir): continue
        for file in files:
            if file.endswith((".csv", ".py", ".txt")): continue
            toplam += 1
            if os.path.splitext(file)[0].lower() not in bilinen_hashler:
                try:
                    shutil.move(os.path.join(root, file), os.path.join(dest_dir, file))
                    tasinan += 1
                except: pass
    print(f"[+] İşlem tamamlandı. {toplam} dosyadan {tasinan} adedi '{os.path.basename(dest_dir)}' klasörüne taşındı.")

