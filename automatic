# ==========================================
# 1. ORTAK YARDIMCI FONKSİYONLAR
# ==========================================

def get_user_paths():
    print("="*60)
    print(" DİZİN YAPILANDIRMASI ".center(60, "="))
    print("="*60)
    malware_dir = input("[?] Malware ana klasör yolunu giriniz:\n>>> ").strip(' "\'')
    yara_dir = input("\n[?] YARA kuralları klasör yolunu giriniz:\n>>> ").strip(' "\'')
    logs_dir = input("\n[?] Uygulama log klasör yolunu giriniz:\n>>> ").strip(' "\'')
    return malware_dir, yara_dir, logs_dir

def set_active_yara(yara_dir, active_rule_name):
    print(f"\n[*] YARA kuralı aktif ediliyor: {active_rule_name}")
    for file in os.listdir(yara_dir):
        if file.endswith(('.yara', '.yara1')):
            aktif_dosya = os.path.join(yara_dir, file)
            base_name = file.rsplit('.yara', 1)[0]
            yeni_isim = os.path.join(yara_dir, base_name + '.yara') if base_name == active_rule_name else os.path.join(yara_dir, base_name + '.yara1')
            
            if aktif_dosya != yeni_isim:
                try: os.rename(aktif_dosya, yeni_isim)
                except: pass
    print(f"[+] Kural ayarlandı: {active_rule_name}.yara")

def wait_for_csv(folder_path, prompt_msg):
    print(f"\n[BEKLENİYOR] {prompt_msg}")
    print(f"Hedef Klasör: {folder_path}")
    while True:
        csv_files = [f for f in os.listdir(folder_path) if f.endswith('.csv')]
        if csv_files:
            time.sleep(2) 
            print(f"[+] CSV dosyası algılandı: {csv_files[0]}")
            return os.path.join(folder_path, csv_files[0])
        time.sleep(3)

def copy_latest_log(logs_dir, dest_dir):
    print(f"\n[*] Log dosyası yedekleniyor...")
    try:
        csv_files = []
        for f in os.listdir(logs_dir):
            if f.lower().endswith('.csv') and 'threats' in f.lower():
                if not re.match(r'^\d{8}_', f):
                    csv_files.append(os.path.join(logs_dir, f))
        
        if not csv_files:
            print("[-] Uygun log dosyası bulunamadı.")
            return None
        
        latest_file = max(csv_files, key=os.path.getctime)
        hedef = os.path.join(dest_dir, os.path.basename(latest_file))
        shutil.copy2(latest_file, hedef)
        
        print(f"[+] Log dosyası kopyalandı: {os.path.basename(latest_file)}")
        return hedef
    except Exception as e:
        print(f"[!] Log kopyalama hatası: {e}")
        return None


# ==========================================
# 2. FAZ 1: IMPHASH MANTIĞI FONKSİYONLARI
# ==========================================

def separator(csv_path, source_dir, dest_dir):
    df = pd.read_csv(csv_path, sep=None, engine='python')
    hash_col = 'sha256' if 'sha256' in df.columns else df.columns[0]
    bilinen_hashler = set(df[hash_col].astype(str).str.strip().str.lower())
    
    tasinan = toplam = 0
    print(f"[*] Ayıklama işlemi başlatıldı. CSV'den {len(bilinen_hashler)} kayıt okundu.")
    for root, dirs, files in os.walk(source_dir):
        if os.path.abspath(root) == os.path.abspath(dest_dir): continue
        for file in files:
            if file.endswith((".csv", ".py", ".txt")): continue
            toplam += 1
            if os.path.splitext(file)[0].lower() not in bilinen_hashler:
                try:
                    shutil.move(os.path.join(root, file), os.path.join(dest_dir, file))
                    tasinan += 1
                except: pass
    print(f"[+] İşlem tamamlandı. {toplam} dosyadan {tasinan} adedi '{os.path.basename(dest_dir)}' klasörüne taşındı.")

def get_imphash(filepath):
    try:
        pe = pefile.PE(filepath, fast_load=True)
        pe.parse_data_directories(directories=[pefile.DIRECTORY_ENTRY["IMAGE_DIRECTORY_ENTRY_IMPORT"]])
        ih = pe.get_imphash()
        pe.close()
        return ih
    except: return None

def generate_yara_rule(malware_dir, output_yara_path):
    print(f"\n[*] rule2.yara kuralı oluşturuluyor...")
    hashes = set()
    for root, dirs, files in os.walk(malware_dir):
        for f in files:
            ih = get_imphash(os.path.join(root, f))
            if ih: hashes.add(ih)
    if not hashes: return set()

    conditions = " or\n            ".join([f'pe.imphash() == "{h}"' for h in hashes])
    with open(output_yara_path, 'w', encoding='utf-8') as f:
        f.write(f'import "pe"\n\nrule rule2_generated\n{{\n    condition:\n        uint16(0) == 0x5A4D and\n        (\n            {conditions}\n        )\n}}')
    print(f"[+] Kural oluşturuldu: {output_yara_path}")
    return hashes

def process_whitelist_rule2(original_hashes):
    print(f"\n[*] Whitelist sonuçları işleniyor...")
    whitelist_imphashes = set()
    for csv_file in [f for f in os.listdir(DIR_STEP3_CSV) if f.endswith('.csv')]:
        df = pd.read_csv(os.path.join(DIR_STEP3_CSV, csv_file), sep=None, engine='python')
        path_col = next((col for col in df.columns if 'path' in col.lower() or 'yol' in col.lower()), df.columns[0])
        for path in df[path_col].dropna():
            if os.path.exists(path):
                ih = get_imphash(path)
                if ih: whitelist_imphashes.add(ih)

    final_hashes = original_hashes - whitelist_imphashes
    conditions = " or\n            ".join([f'pe.imphash() == "{h}"' for h in final_hashes])
    final_path = os.path.join(BASE_DIR, "final_rule2.yara")
    with open(final_path, 'w', encoding='utf-8') as f:
        f.write(f'import "pe"\n\nrule rule2_final\n{{\n    condition:\n        uint16(0) == 0x5A4D and\n        (\n            {conditions}\n        )\n}}')
    print(f"[+] FAZ 1 Tamamlandı. final_rule2.yara oluşturuldu.")


# ==========================================
# 3. FAZ 2: YARA-FORGE SEÇİCİ VE FP TEMİZLEYİCİ
# ==========================================

YARA_NAME_RE = re.compile(r'^[A-Za-z][A-Za-z0-9_]{4,}$')
def looks_like_rule_name(val):
    return bool(YARA_NAME_RE.match(val)) and '_' in val

def load_threat_names_from_log(csv_path):
    names = set()
    with open(csv_path, newline='', encoding='utf-8-sig') as f:
        reader = csv.DictReader(f)
        fieldnames = reader.fieldnames or []
        for row in reader:
            for col in fieldnames:
                cell = (row.get(col) or "").strip()
                if looks_like_rule_name(cell):
                    names.add(cell)
                    break 
    return names

def create_secilen_kurallar(log_csv_path, yara_dir):
    print("\n" + "-"*50)
    print("[*] FAZ 2: Loglardan kuralların süzülmesi başlatılıyor.")
    
    threat_names = load_threat_names_from_log(log_csv_path)
    print(f"[*] Log dosyasından {len(threat_names)} adet YARA kuralı tespit edildi.")
    if not threat_names:
        print("[-] Log dosyasında geçerli kural ismi bulunamadı.")
        return False

    forge_path = None
    for f in os.listdir(yara_dir):
        if f.startswith('yara-forge'):
            forge_path = os.path.join(yara_dir, f)
            break
            
    if not forge_path:
        print("[-] Hedef dizinde 'yara-forge' kuralı bulunamadı.")
        return False

    print(f"[*] {os.path.basename(forge_path)} okunuyor...")
    with open(forge_path, "rb") as f:
        forge_content = f.read().replace(b"\r\n", b"\n").replace(b"\r", b"\n").decode("utf-8", errors="replace")

    rule_starts = [(m.start(), m.group(1)) for m in re.finditer(r'(?m)^rule\s+(\w+)', forge_content)]
    matched_blocks = []
    
    for i, (start, name) in enumerate(rule_starts):
        if name in threat_names:
            end = rule_starts[i + 1][0] if i + 1 < len(rule_starts) else len(forge_content)
            matched_blocks.append(forge_content[start:end])

    secilen_path = os.path.join(yara_dir, "secilen_kurallar.yara1")
    with open(secilen_path, "w", encoding="utf-8") as f:
        f.write("/* Otomatik Suzulen Kurallar */\n\n")
        imports = set(re.findall(r'^import\s+"[^"]+"', forge_content[:10000], re.MULTILINE))
        for imp in imports: f.write(imp + "\n")
        f.write("\n")
        for block in matched_blocks: f.write(block.rstrip() + "\n\n")

    print(f"[+] {len(matched_blocks)} adet kural 'secilen_kurallar.yara' dosyasına aktarıldı.")
    return True

def remove_fp_from_secilen_kurallar(yara_dir):
    print("\n" + "-"*50)
    print("[*] Kural Temizliği (False Positive) işlemi başlatılıyor.")
    
    silinecek_kurallar = set()
    while True:
        kural = input("\n[?] Hatalı (False Positive) kural adını giriniz (İşlemi sonlandırmak için 'bitti' yazınız):\n>>> ").strip()
        if not kural or kural.lower() in ['bitti', 'h', 'hayır', 'hayir']:
            break
        silinecek_kurallar.add(kural)
    
    if not silinecek_kurallar:
        print("[+] Hatalı kural girilmedi. İşlem sonlandırılıyor.")
        return
        
    print(f"\n[*] Silinecek kurallar: {', '.join(silinecek_kurallar)}")
    
    secilen_path = None
    for f in os.listdir(yara_dir):
        if f.startswith('secilen_kurallar'):
            secilen_path = os.path.join(yara_dir, f)
            break
            
    if not secilen_path: return

    with open(secilen_path, 'r', encoding='utf-8') as f:
        lines = f.readlines()

    yeni_satirlar = []
    atla_modu = False
    parantez_sayaci = 0

    for line in lines:
        if not atla_modu:
            kelimeler = line.split()
            if len(kelimeler) >= 2 and kelimeler[0] == "rule":
                kural_adi = kelimeler[1].strip("{:")
                if kural_adi in silinecek_kurallar:
                    atla_modu = True
                    parantez_sayaci = line.count("{") - line.count("}")
                    continue
            yeni_satirlar.append(line)
        else:
            parantez_sayaci += line.count("{")
            parantez_sayaci -= line.count("}")
            if parantez_sayaci <= 0:
                atla_modu = False

    final_yara_path = os.path.join(BASE_DIR, "final_secilen_kurallar.yara")
    with open(final_yara_path, 'w', encoding='utf-8') as f:
        f.writelines(yeni_satirlar)
        
    print(f"[+] Hatalı kurallar dosyadan silindi.")
    print(f"[+] Temizlenmiş YARA dosyası oluşturuldu: {final_yara_path}")


