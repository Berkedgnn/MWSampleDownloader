# ANA İŞ AKIŞI (PIPELINE)
# ==========================================
def main():
    malware_ana_dizin, yara_dir, logs_dir = get_user_paths()

    hatali_dizin = False
    for d_path, d_name in [(malware_ana_dizin, "Malware"), (yara_dir, "YARA"), (logs_dir, "Logs")]:
        if not os.path.exists(d_path):
            print(f"\n[HATA] Belirtilen dizin bulunamadı: {d_path}")
            hatali_dizin = True
    if hatali_dizin: return

    print("\n" + "="*50)
    print(" İŞLEM BAŞLATILIYOR ".center(50, "="))
    print("="*50)

    # --- FAZ 1: IMPHASH SÜRECİ ---
    set_active_yara(yara_dir, "output")
    csv1 = wait_for_csv(DIR_STEP1_CSV, "Lütfen output.yara tarama sonucunu '1_Adim_Output_CSV' klasörüne kopyalayınız.")
    separator(csv1, malware_ana_dizin, DIR_KACANLAR_1)

    set_active_yara(yara_dir, "yara-forge")
    csv2 = wait_for_csv(DIR_STEP2_CSV, "Lütfen yara-forge.yara tarama sonucunu '2_Adim_YaraForge_CSV' klasörüne kopyalayınız.")
    separator(csv2, DIR_KACANLAR_1, DIR_KACANLAR_2)
    
    yedeklenen_log = copy_latest_log(logs_dir, DIR_INCELEME_LOGLARI)

    rule2_path = os.path.join(yara_dir, "rule2.yara1") 
    original_hashes = generate_yara_rule(DIR_KACANLAR_2, rule2_path)
    
    set_active_yara(yara_dir, "rule2") 
    print(f"\n[BEKLEMEDE] rule2.yara kuralı aktif.")
    print("Lütfen rule2.yara ile Whitelist taramasını gerçekleştiriniz.")
    print("Tarama sonucunu (CSV) '3_Adim_Whitelist_Rule2_CSV' klasörüne kopyalayınız.")
    input("İşlemi tamamladıktan sonra devam etmek için ENTER tuşuna basınız...")
    
    process_whitelist_rule2(original_hashes)
    
    # --- FAZ 2: FORGE KURAL SÜZME VE TEMİZLEME SÜRECİ ---
    if yedeklenen_log:
        basarili = create_secilen_kurallar(yedeklenen_log, yara_dir)
        if basarili:
            set_active_yara(yara_dir, "secilen_kurallar")
            
            print(f"\n[BEKLEMEDE] secilen_kurallar.yara kuralı aktif.")
            print("Lütfen secilen_kurallar.yara ile Whitelist taramasını gerçekleştiriniz.")
            input("Tarama tamamlandıktan sonra devam etmek için ENTER tuşuna basınız...")
            
            remove_fp_from_secilen_kurallar(yara_dir)
    else:
        print("\n[-] Uygulama logu kopyalanamadığı için Faz 2'ye geçilemedi.")

    print(f"\n[+] İŞLEMLER BAŞARIYLA TAMAMLANDI. Çıktı Dizini: {BASE_DIR}")

if __name__ == "__main__":
    main()
